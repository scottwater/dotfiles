if [ -z "${ZSH_VERSION:-}" ]; then
  if [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv bash)"
  elif [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv bash)"
  elif [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv bash)"
  fi
  return 0 2>/dev/null || exit 0
fi

export PATH="$HOME/.local/bin:$PATH"
if [ -f "$HOME/.atuin/bin/env" ]; then
  . "$HOME/.atuin/bin/env"
fi

{{- if eq .chezmoi.os "linux" }}
# Set UTF-8 locale for proper character rendering (Linux only)
export LANG=C.UTF-8
export LC_ALL=C.UTF-8
if [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv zsh)"
fi
{{- end }}

if command -v atuin >/dev/null 2>&1; then
  eval "$(atuin init zsh)"
fi

if command -v stooges >/dev/null 2>&1; then
  eval "$(stooges shell-init zsh)"
fi

if command -v mise >/dev/null 2>&1 && [[ ":$PATH:" != *":$HOME/.local/share/mise/shims:"* ]]; then
  if [[ "$TERM_PROGRAM" == "vscode" ]]; then
    eval "$(mise activate zsh --shims)"
  else
    eval "$(mise activate zsh)"
  fi
fi
if command -v fnox >/dev/null 2>&1; then
  eval "$(fnox activate zsh)"
fi

# Pure prompt
fpath+=($HOME/.zsh/pure)
autoload -U promptinit; promptinit
prompt pure

# zsh-autosuggestions defaults to `fg=8`; in the Alucard light terminal
# palette that is white, making type-ahead suggestions disappear.
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=#635D97'

if command -v brew >/dev/null 2>&1; then
  source $(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
  source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh
elif [ -f /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]; then
  source /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
  source /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh
fi

source $HOME/zsh/zsh-z.plugin.zsh
autoload -U compinit; compinit
zstyle ':completion:*' menu select
# Dracula Pro Alucard completion colors for light terminal backgrounds.
zstyle ':completion:*' list-colors \
  'no=38;2;31;31;31' \
  'fi=38;2;31;31;31' \
  'di=38;2;3;106;150' \
  'ln=38;2;100;74;201' \
  'ex=38;2;20;113;10' \
  'ma=48;2;207;207;222;38;2;31;31;31'
zstyle ':completion:*:descriptions' format '%F{#644AC9}%d%f'
zstyle ':completion:*:messages' format '%F{#635D97}%d%f'
zstyle ':completion:*:warnings' format '%F{#CB3A2A}No matches for: %d%f'

export EDITOR=nvim
set -o emacs

source "$HOME/zsh/aliases.zsh"

# PI
export PI_SUBAGENT_RUNTIME_ROOT="$HOME/.pi/agent/git/github.com/nicobailon/pi-subagents"

# Mur Pretty Delta
export DELTA_FEATURES="diff-so-fancy alucard"

# Source local overrides if present
[[ -f "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"

export HOMEBREW_NO_AUTO_UPDATE=1
