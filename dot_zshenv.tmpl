# Codex may run non-login, non-interactive zsh; .zprofile/.zshrc are skipped.
# Keep this narrow: only adjust PATH when running inside Codex.
if [[ -n "${CODEX_SHELL:-}" || "${__CFBundleIdentifier:-}" == "com.openai.codex" || "${CODEX_INTERNAL_ORIGINATOR_OVERRIDE:-}" == "Codex Desktop" || "$(ps -p "${PPID:-0}" -o comm= 2>/dev/null)" == *"/Codex" ]] && [[ -d "$HOME/.local/share/mise/shims" ]]; then
  path=("$HOME/.local/share/mise/shims" ${path:#$HOME/.local/share/mise/shims})
  export PATH
fi
