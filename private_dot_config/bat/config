# Bat configuration
# Using Dracula Pro Alucard to match theming across tools
# (Zed, Delta, LazyGit, Neovim, Ghostty)

# Theme - Dracula Pro Alucard syntax theme
# (Delta alucard, Ghostty, Zed, LazyGit, etc.)
--theme="alucard"

# Show line numbers
--style="numbers,changes,header,grid"

# Use italic text (works in most modern terminals)
--italic-text=always

# Set tab width
--tabs=4

# Enable paging for long output
--paging=auto

# Map additional file types
--map-syntax "*.conf:INI"
--map-syntax ".gitconfig:INI"
--map-syntax "*.envrc:Bash"
--map-syntax ".envrc:Bash"
